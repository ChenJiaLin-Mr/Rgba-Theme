{
	"name": "Rgba Theme - Xcode Light",
	"colors": {
		"editor.background": "#ffffff",
		"editor.foreground": "#000000",
		"activityBarBadge.background": "#0071e3",
		"sideBarTitle.foreground": "#1c1c1e",
		"editor.selectionBackground": "#b3d7ff",
		"editor.lineHighlightBackground": "#f2f2f7",
		"editorCursor.foreground": "#000000",
		"editorLineNumber.foreground": "#aeaeb2",
		"editorLineNumber.activeForeground": "#1c1c1e",
		"editorGutter.background": "#ffffff",
		"editor.findMatchBackground": "#0071e340",
		"editor.findMatchHighlightBackground": "#0071e320",
		"editor.wordHighlightBackground": "#b3d7ff80",
		"statusBar.background": "#e5e5ea",
		"statusBar.foreground": "#1c1c1e",
		"titleBar.activeBackground": "#f2f2f7",
		"titleBar.activeForeground": "#1c1c1e",
		"activityBar.background": "#f2f2f7",
		"activityBar.foreground": "#1c1c1e",
		"activityBar.border": "#d1d1d6",
		"sideBar.background": "#f9f9fb",
		"sideBar.foreground": "#1c1c1e",
		"sideBar.border": "#d1d1d6",
		"tab.activeBackground": "#ffffff",
		"tab.activeForeground": "#000000",
		"tab.inactiveBackground": "#f2f2f7",
		"tab.inactiveForeground": "#8e8e93",
		"tab.border": "#d1d1d6",
		"panel.background": "#f9f9fb",
		"panel.border": "#d1d1d6",
		"terminal.background": "#ffffff",
		"terminal.foreground": "#000000",
		"input.background": "#ffffff",
		"input.foreground": "#000000",
		"input.border": "#c7c7cc",
		"button.background": "#0071e3",
		"button.foreground": "#ffffff"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "fontStyle": "italic", "foreground": "#5c6e74" }
		},
		{
			"name": "Variables",
			"scope": ["variable", "string constant.other.placeholder"],
			"settings": { "foreground": "#000000" }
		},
		{
			"name": "Keyword, Storage",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#ad3da4" }
		},
		{
			"name": "Operator, Control",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": { "foreground": "#ad3da4" }
		},
		{
			"name": "String",
			"scope": ["string", "constant.other.symbol", "constant.other.key"],
			"settings": { "foreground": "#c41a16" }
		},
		{
			"name": "Number, Constant",
			"scope": ["constant.numeric", "constant.language", "constant.character", "constant.escape"],
			"settings": { "foreground": "#1c00cf" }
		},
		{
			"name": "Function",
			"scope": ["entity.name.function", "meta.function-call", "variable.function", "support.function"],
			"settings": { "foreground": "#3900a0" }
		},
		{
			"name": "Class, Type",
			"scope": ["entity.name", "support.type", "support.class"],
			"settings": { "foreground": "#0b4f79" }
		},
		{
			"name": "Tag",
			"scope": ["entity.name.tag"],
			"settings": { "foreground": "#ad3da4" }
		},
		{
			"name": "Attribute",
			"scope": ["entity.other.attribute-name"],
			"settings": { "foreground": "#836c28" }
		},
		{
			"name": "Punctuation",
			"scope": ["punctuation"],
			"settings": { "foreground": "#000000" }
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#ff3b30" }
		},
		{
			"name": "Inserted",
			"scope": ["markup.inserted"],
			"settings": { "foreground": "#3900a0" }
		},
		{
			"name": "Deleted",
			"scope": ["markup.deleted"],
			"settings": { "foreground": "#ff3b30" }
		}
	]
}
