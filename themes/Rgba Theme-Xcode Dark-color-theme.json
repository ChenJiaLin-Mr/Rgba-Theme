{
	"name": "Rgba Theme - Xcode Dark",
	"colors": {
		"editor.background": "#1f1f24",
		"editor.foreground": "#ffffff",
		"activityBarBadge.background": "#0a84ff",
		"sideBarTitle.foreground": "#ebebf5",
		"editor.selectionBackground": "#2f4f7f",
		"editor.lineHighlightBackground": "#2a2a30",
		"editorCursor.foreground": "#ffffff",
		"editorLineNumber.foreground": "#636366",
		"editorLineNumber.activeForeground": "#ebebf5",
		"editorGutter.background": "#1f1f24",
		"editor.findMatchBackground": "#0a84ff40",
		"editor.findMatchHighlightBackground": "#0a84ff20",
		"editor.wordHighlightBackground": "#2f4f7f80",
		"statusBar.background": "#2c2c2e",
		"statusBar.foreground": "#ebebf5",
		"titleBar.activeBackground": "#2c2c2e",
		"titleBar.activeForeground": "#ffffff",
		"activityBar.background": "#2c2c2e",
		"activityBar.foreground": "#ffffff",
		"activityBar.border": "#1c1c1e",
		"sideBar.background": "#252528",
		"sideBar.foreground": "#ebebf5",
		"sideBar.border": "#1c1c1e",
		"tab.activeBackground": "#1f1f24",
		"tab.activeForeground": "#ffffff",
		"tab.inactiveBackground": "#2c2c2e",
		"tab.inactiveForeground": "#636366",
		"tab.border": "#1c1c1e",
		"panel.background": "#252528",
		"panel.border": "#1c1c1e",
		"terminal.background": "#1f1f24",
		"terminal.foreground": "#ffffff",
		"input.background": "#1c1c1e",
		"input.foreground": "#ffffff",
		"input.border": "#3a3a3c",
		"button.background": "#0a84ff",
		"button.foreground": "#ffffff"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "fontStyle": "italic", "foreground": "#7f8c98" }
		},
		{
			"name": "Variables",
			"scope": ["variable", "string constant.other.placeholder"],
			"settings": { "foreground": "#ffffff" }
		},
		{
			"name": "Keyword, Storage",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#fc5fa3" }
		},
		{
			"name": "Operator, Control",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": { "foreground": "#fc5fa3" }
		},
		{
			"name": "String",
			"scope": ["string", "constant.other.symbol", "constant.other.key"],
			"settings": { "foreground": "#fc6a5d" }
		},
		{
			"name": "Number, Constant",
			"scope": ["constant.numeric", "constant.language", "constant.character", "constant.escape"],
			"settings": { "foreground": "#d9c97c" }
		},
		{
			"name": "Function",
			"scope": ["entity.name.function", "meta.function-call", "variable.function", "support.function"],
			"settings": { "foreground": "#67b7a4" }
		},
		{
			"name": "Class, Type",
			"scope": ["entity.name", "support.type", "support.class"],
			"settings": { "foreground": "#5dd8ff" }
		},
		{
			"name": "Tag",
			"scope": ["entity.name.tag"],
			"settings": { "foreground": "#fc5fa3" }
		},
		{
			"name": "Attribute",
			"scope": ["entity.other.attribute-name"],
			"settings": { "foreground": "#9fa1a6" }
		},
		{
			"name": "Punctuation",
			"scope": ["punctuation"],
			"settings": { "foreground": "#ffffff" }
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#ff3b30" }
		},
		{
			"name": "Inserted",
			"scope": ["markup.inserted"],
			"settings": { "foreground": "#67b7a4" }
		},
		{
			"name": "Deleted",
			"scope": ["markup.deleted"],
			"settings": { "foreground": "#ff3b30" }
		}
	]
}
